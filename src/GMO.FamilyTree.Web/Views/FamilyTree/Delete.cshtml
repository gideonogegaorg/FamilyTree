@model GMO.FamilyTree.Web.Data.FamilyTree
@{
    ViewData["Title"] = "Delete Family Tree";
}
<h1 class="ft-page-title">Delete tree</h1>
<p class="text-danger">Are you sure you want to delete <strong>@Model.Name</strong>?</p>
<p class="ft-page-lead">All members and relationships in this tree will be permanently removed.</p>
<dl class="row mb-0">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>
</dl>
<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <div class="ft-form-actions">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-controller="Home" asp-action="Index" class="ft-link">Cancel</a>
    </div>
</form>
