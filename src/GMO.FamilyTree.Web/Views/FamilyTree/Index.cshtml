@model IEnumerable<GMO.FamilyTree.Web.Data.FamilyTree>
@{
    ViewData["Title"] = "Family Trees";
    ViewData["WideContent"] = true;
    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}
<h1 class="ft-page-title">Family trees</h1>
<p class="ft-page-lead">
    <a asp-action="Create" class="ft-link">Create new tree</a>
    &middot;
    <a asp-controller="Home" asp-action="Index" class="ft-link">Back to tree view</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Access</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var isOwner = item.OwnerId == userId;
            <tr>
                <td>@item.Name</td>
                <td>@(isOwner ? "Owner" : "Shared")</td>
                <td class="text-nowrap">
                    <form asp-controller="Account" asp-action="SwitchFamilyTree" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn btn-link ft-link p-0 align-baseline">Open</button>
                    </form>
                    @if (isOwner)
                    {
                        <text>&middot;</text>
                        <a asp-controller="Share" asp-action="Manage" asp-route-treeId="@item.Id" class="ft-link">Share</a>
                        <text>&middot;</text>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="ft-link">Rename</a>
                        <text>&middot;</text>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="ft-link">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
