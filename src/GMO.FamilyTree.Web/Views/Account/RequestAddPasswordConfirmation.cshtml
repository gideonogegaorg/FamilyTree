@model string?
@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Check your email";
}

<div class="ft-auth-card mx-auto">
    <h1 class="ft-page-title">Check your email</h1>
    <p class="ft-auth-subtitle">
        We sent a confirmation link@(string.IsNullOrEmpty(Model) ? "" : $" to {Model}"). Open it to choose a password.
        After that, password sign-in will require a verification code sent to your email.
    </p>
    <p class="mb-0 text-center small">
        <a asp-controller="Home" asp-action="Index">Back to tree</a>
    </p>
</div>
