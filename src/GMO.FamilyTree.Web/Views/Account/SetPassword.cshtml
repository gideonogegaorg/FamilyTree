@model GMO.FamilyTree.Web.Models.SetPasswordViewModel
@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Set password";
}

<div class="ft-auth-card mx-auto">
    <h1 class="ft-page-title">Set a password</h1>
    <p class="ft-auth-subtitle">
        Add a password for email sign-in. The next time you sign in with your email and password, we will send a verification code to your email.
    </p>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <output class="alert alert-success d-block">@Model.StatusMessage</output>
    }

    <form asp-action="SetPassword" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2" role="alert"></div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary w-100 mb-2">Set password</button>
    </form>
    <p class="mb-0 text-center small">
        <a asp-controller="Home" asp-action="Index">Back to tree</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
