@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Add password";
}

<div class="ft-auth-card mx-auto">
    <h1 class="ft-page-title">Add a password</h1>
    <p class="ft-auth-subtitle">
        To protect your account, we email a confirmation link to verify you own this address before a password can be set.
    </p>
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2" role="alert"></div>
    <form asp-action="RequestAddPassword" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-primary w-100 mb-2">Email me a confirmation link</button>
    </form>
    <p class="mb-0 text-center small">
        <a asp-controller="Home" asp-action="Index">Back to tree</a>
    </p>
</div>
