@model string
@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Add password";
}

<div class="ft-auth-card mx-auto">
    <h1 class="ft-page-title">Add password</h1>
    <p class="ft-auth-subtitle text-danger">@Model</p>
    <p class="mb-0 text-center small">
        <a asp-action="Login">Back to sign in</a>
    </p>
</div>
