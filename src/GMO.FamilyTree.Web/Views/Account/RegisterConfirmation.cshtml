@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Confirm your email";
    var email = ViewData["Email"] as string;
    var emailRateLimited = TempData["EmailRateLimited"] as bool? == true;
}

<div class="ft-auth-card mx-auto">
    <h1 class="ft-page-title">Check your email</h1>
    @if (emailRateLimited)
    {
        <div class="alert alert-warning" role="alert">
            Too many email requests recently. Wait a few minutes and use Resend confirmation below.
        </div>
    }
    <p class="ft-auth-subtitle">
        @if (!string.IsNullOrEmpty(email))
        {
            <text>We sent a confirmation link to <strong>@email</strong>. Confirm your email, then sign in.</text>
        }
        else
        {
            <text>We sent a confirmation link to your email. Confirm it, then sign in.</text>
        }
    </p>
    <p class="mb-0 text-center small">
        <a asp-action="ResendConfirmationEmail" asp-route-email="@email">Resend confirmation email</a>
        &middot;
        <a asp-action="Login">Back to sign in</a>
    </p>
</div>
