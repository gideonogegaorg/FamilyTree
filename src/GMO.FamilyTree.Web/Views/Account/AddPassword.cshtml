@model GMO.FamilyTree.Web.Models.AddPasswordViewModel
@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Choose a password";
}

<div class="ft-auth-card mx-auto">
    <h1 class="ft-page-title">Choose a password</h1>
    <p class="ft-auth-subtitle">
        Your email was confirmed. Set a password for this account. The next time you sign in with your email and password, we will send a verification code to your email.
    </p>

    <form asp-action="AddPassword" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2" role="alert"></div>
        <input asp-for="UserId" type="hidden" />
        <input asp-for="Code" type="hidden" />
        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary w-100 mb-2">Set password</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
