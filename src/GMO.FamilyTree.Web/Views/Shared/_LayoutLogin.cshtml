@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @if (!Configuration.GetValue<bool>("IsProduction"))
    {
        <meta name="robots" content="noindex, nofollow" />
    }
    <title>@ViewData["Title"] - Family Tree</title>
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" asp-append-version="true" />
    <link rel="icon" href="~/favicon.ico" sizes="any" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/apple-touch-icon.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <main class="ft-auth-page">
        <a class="ft-auth-back" asp-controller="Home" asp-action="Landing">&larr; Back</a>
        @RenderBody()
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
