@model GMO.FamilyTree.Web.ViewComponents.TreeToolbarViewModel
@using GMO.FamilyTree.Web.Data

<div class="ft-toolbar">
    <div class="ft-toolbar-row">
        <div class="ft-tree-picker">
            <div class="ft-tree-picker-wrap">
                <button type="button" class="ft-tree-picker-btn" aria-expanded="false" aria-haspopup="true">
                    <span class="ft-tree-picker-name">@Model.CurrentTreeName</span>
                    <span class="ft-tree-picker-chevron" aria-hidden="true">&#9662;</span>
                </button>
                <div class="ft-tree-picker-menu" hidden>
                    @foreach (var tree in Model.FamilyTrees)
                    {
                        <div class="ft-tree-picker-row">
                            <form asp-controller="Account" asp-action="SwitchFamilyTree" method="post" class="ft-tree-picker-switch-form">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="ft-tree-picker-item @(tree.Id == Model.CurrentTreeId ? "active" : "")"
                                        @(tree.Id == Model.CurrentTreeId ? "aria-current=\"true\"" : null)>
                                    @tree.Name
                                    @if (!tree.IsOwner)
                                    {
                                        <span class="text-muted small">(@tree.AccessLevel)</span>
                                    }
                                </button>
                                <input type="hidden" name="id" value="@tree.Id" />
                            </form>
                            @if (tree.IsOwner)
                            {
                                <a asp-controller="Share"
                                   asp-action="Manage"
                                   asp-route-treeId="@tree.Id"
                                   class="ft-tree-picker-edit"
                                   aria-label="Share @tree.Name"
                                   title="Share @tree.Name">
                                    <span aria-hidden="true">&#128279;</span>
                                </a>
                                <a asp-controller="FamilyTree"
                                   asp-action="Edit"
                                   asp-route-id="@tree.Id"
                                   class="ft-tree-picker-edit"
                                   aria-label="Rename @tree.Name"
                                   title="Rename @tree.Name">
                                    <span aria-hidden="true">&#9998;</span>
                                </a>
                                <form asp-controller="Account" asp-action="DeleteFamilyTree" method="post" class="ft-tree-picker-delete-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@tree.Id" />
                                    <button type="submit"
                                            class="ft-tree-picker-delete"
                                            aria-label="Delete @tree.Name"
                                            title="Delete @tree.Name">
                                        <span aria-hidden="true">&#128465;</span>
                                    </button>
                                </form>
                            }
                        </div>
                    }
                    @if (Model.FamilyTrees.Count == 0)
                    {
                        <span class="ft-tree-picker-empty">No family trees yet</span>
                    }
                </div>
            </div>
            <a asp-controller="FamilyTree" asp-action="Create" class="ft-tree-create-btn" title="Create new family tree" aria-label="Create new family tree">+</a>
            @if (Model.CanManageSharing && Model.CurrentTreeId > 0)
            {
                <a asp-controller="Share"
                   asp-action="Manage"
                   asp-route-treeId="@Model.CurrentTreeId"
                   class="ft-tree-create-btn"
                   title="Share this family tree"
                   aria-label="Share this family tree">&#128279;</a>
            }
        </div>
        <div class="ft-toolbar-spacer"></div>
        @if (Model.HasMembers && Model.FocusMemberId.HasValue)
        {
            <button type="button"
                    class="ft-jump-to-me btn btn-sm btn-outline-secondary"
                    data-focus-member-id="@Model.FocusMemberId.Value">
                Jump to you
            </button>
        }
    </div>
    <div class="ft-subbar">
        <div class="ft-pill-group">
            <span>Layout</span>
            <fieldset class="ft-pills border-0 p-0 m-0">
                <legend class="visually-hidden">Tree layout orientation</legend>
                <form asp-controller="Account" asp-action="SetTreeViewOrientation" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orientation" value="@((int)TreeViewOrientation.Horizontal)" />
                    <button type="submit" class="@(Model.TreeViewOrientation == TreeViewOrientation.Horizontal ? "active" : "")">Horizontal</button>
                </form>
                <form asp-controller="Account" asp-action="SetTreeViewOrientation" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orientation" value="@((int)TreeViewOrientation.Vertical)" />
                    <button type="submit" class="@(Model.TreeViewOrientation == TreeViewOrientation.Vertical ? "active" : "")">Vertical</button>
                </form>
            </fieldset>
        </div>
        <div class="ft-pill-group">
            <span>Lineage</span>
            <fieldset class="ft-pills border-0 p-0 m-0">
                <legend class="visually-hidden">Lineage mode</legend>
                <form asp-controller="Account" asp-action="SetLineageMode" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="mode" value="@((int)LineageMode.Paternal)" />
                    <button type="submit" class="@(Model.LineageMode == LineageMode.Paternal ? "active" : "")">Paternal</button>
                </form>
                <form asp-controller="Account" asp-action="SetLineageMode" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="mode" value="@((int)LineageMode.Maternal)" />
                    <button type="submit" class="@(Model.LineageMode == LineageMode.Maternal ? "active" : "")">Maternal</button>
                </form>
            </fieldset>
        </div>
        <div class="ft-pill-group">
            <span>View</span>
            <div class="ft-view-picker-wrap">
                <button type="button" class="ft-view-picker-btn" aria-expanded="false" aria-haspopup="menu">
                    <span class="ft-view-picker-label">@Model.TreeCardViewMode.GetLabel()</span>
                    <span class="ft-tree-picker-chevron" aria-hidden="true">&#9662;</span>
                </button>
                <div class="ft-view-picker-menu" role="menu" hidden>
                    <div class="ft-view-picker-section">
                        <div class="ft-view-picker-heading">Cards</div>
                        @foreach (var viewMode in new[] { TreeCardViewMode.Compact, TreeCardViewMode.Standard, TreeCardViewMode.Large, TreeCardViewMode.Details })
                        {
                            <form asp-controller="Account" asp-action="SetTreeCardViewMode" method="post" class="ft-view-picker-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="mode" value="@((int)viewMode)" />
                                <button type="submit" class="ft-view-picker-item @(Model.TreeCardViewMode == viewMode ? "active" : "")" role="menuitem">
                                    @viewMode.GetLabel()
                                </button>
                            </form>
                        }
                    </div>
                    <div class="ft-view-picker-section">
                        <div class="ft-view-picker-heading">Photos only</div>
                        @foreach (var viewMode in new[] { TreeCardViewMode.PhotoSmall, TreeCardViewMode.PhotoMedium, TreeCardViewMode.PhotoLarge, TreeCardViewMode.PhotoExtraLarge })
                        {
                            <form asp-controller="Account" asp-action="SetTreeCardViewMode" method="post" class="ft-view-picker-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="mode" value="@((int)viewMode)" />
                                <button type="submit" class="ft-view-picker-item @(Model.TreeCardViewMode == viewMode ? "active" : "")" role="menuitem">
                                    @viewMode.GetLabel()
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
