@model GMO.FamilyTree.Web.ViewComponents.UserMenuViewModel

@if (string.IsNullOrEmpty(Model.Email))
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" asp-controller="Account" asp-action="Login">Sign in</a>
        </li>
    </ul>
}
else
{
<div class="d-flex align-items-center gap-3">
    <div class="d-none d-md-flex flex-column align-items-end text-end user-menu-email" style="line-height: 1.25;">
        <span class="small">@Model.Email</span>
    </div>
    <div class="dropdown position-relative">
        <button class="btn btn-link p-0 border-0 rounded-circle" type="button" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            @if (!string.IsNullOrEmpty(Model.PhotoUrl))
            {
                <img src="@Model.PhotoUrl" alt="Profile" data-profile-photo class="rounded-circle" width="36" height="36" style="object-fit: cover;" />
            }
            else
            {
                <span class="d-inline-flex align-items-center justify-content-center rounded-circle user-menu-avatar" data-profile-photo-placeholder style="width: 36px; height: 36px; font-size: 1rem;" aria-hidden="true">@(Model.Email.Length > 0 ? char.ToUpperInvariant(Model.Email[0]) : '?')</span>
            }
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow mt-2 user-menu-dropdown" aria-labelledby="userMenuDropdown" style="min-width: 240px;">
            <li class="px-3 py-2 border-bottom">
                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="dropdown-photo-link profile-photo-open position-relative rounded-circle flex-shrink-0 border-0 p-0 bg-transparent" title="Add or change your picture">
                        @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                        {
                            <img src="@Model.PhotoUrl" alt="" data-profile-photo class="rounded-circle" width="48" height="48" style="object-fit: cover; display: block;" />
                        }
                        else
                        {
                            <span class="d-inline-flex align-items-center justify-content-center rounded-circle user-menu-avatar" data-profile-photo-placeholder style="width: 48px; height: 48px;">@(Model.Email.Length > 0 ? char.ToUpperInvariant(Model.Email[0]) : '?')</span>
                        }
                        <span class="user-menu-change-picture-hint position-absolute top-0 start-0 end-0 bottom-0 d-flex align-items-center justify-content-center rounded-circle bg-dark bg-opacity-75 text-white small text-center px-1" style="opacity: 0; transition: opacity 0.2s; pointer-events: none;">Add or change your picture</span>
                    </button>
                    <div class="small">
                        <strong>@Model.Email</strong>
                    </div>
                </div>
            </li>
            <li><hr class="dropdown-divider" /></li>
            <li>
                <button type="button" class="dropdown-item profile-photo-open">Change profile picture</button>
            </li>
            <li>
                <form asp-controller="Account" asp-action="SignOut" method="post">
                    <button type="submit" class="dropdown-item text-danger">Sign out</button>
                </form>
            </li>
        </ul>
    </div>
</div>

<div class="modal fade" id="profilePhotoModal" tabindex="-1" aria-labelledby="profilePhotoModalLabel" aria-hidden="true" data-photo-url="@Model.PhotoUrl">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="profilePhotoModalLabel">Profile picture</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="profile-photo-form" asp-controller="Account" asp-action="UploadPhoto" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="profile-photo-preview-wrap mb-3 text-center">
                        @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                        {
                            <img id="profile-photo-preview" src="@Model.PhotoUrl" alt="" class="rounded-circle profile-photo-preview-img" />
                            <span id="profile-photo-preview-placeholder" class="d-none profile-photo-preview-placeholder rounded-circle user-menu-avatar d-inline-flex align-items-center justify-content-center">@(Model.Email.Length > 0 ? char.ToUpperInvariant(Model.Email[0]) : '?')</span>
                        }
                        else
                        {
                            <img id="profile-photo-preview" src="" alt="" class="rounded-circle profile-photo-preview-img d-none" />
                            <span id="profile-photo-preview-placeholder" class="profile-photo-preview-placeholder rounded-circle user-menu-avatar d-inline-flex align-items-center justify-content-center">@(Model.Email.Length > 0 ? char.ToUpperInvariant(Model.Email[0]) : '?')</span>
                        }
                    </div>
                    <div class="mb-3">
                        <label for="profile-photo-file" class="form-label">Choose image (JPG, PNG, GIF, WebP)</label>
                        <input type="file" name="photo" id="profile-photo-file" class="form-control" accept=".jpg,.jpeg,.png,.gif,.webp" />
                    </div>
                    <p id="profile-photo-error" class="text-danger small mb-0 d-none" role="alert"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="profile-photo-submit">Upload</button>
                </div>
            </form>
        </div>
    </div>
</div>
}
