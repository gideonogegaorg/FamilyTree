@model GMO.FamilyTree.Web.Models.AddRelationViewModel
@{
    ViewData["Title"] = "Add first person";
}
<h1 class="ft-page-title">Add first person</h1>
<p class="ft-page-lead">Your family tree is empty. Add yourself or another family member to get started.</p>
<form asp-action="AddFirstMember" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="FamilyTreeId" />
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Name</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="NickName" class="form-label">Nickname</label>
        <input asp-for="NickName" class="form-control" />
    </div>
    <partial name="_DateOfBirthField" />
    <div class="mb-3 form-check">
        <input asp-for="IsMale" class="form-check-input" />
        <label asp-for="IsMale" class="form-check-label">Male</label>
    </div>
    <div class="mb-3 form-check">
        <input asp-for="SetAsMe" class="form-check-input" />
        <label asp-for="SetAsMe" class="form-check-label">This is me (link to my account)</label>
    </div>
    <div class="ft-form-actions">
        <button type="submit" class="btn btn-primary">Add</button>
        <a asp-action="Index" class="ft-link">Cancel</a>
    </div>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
