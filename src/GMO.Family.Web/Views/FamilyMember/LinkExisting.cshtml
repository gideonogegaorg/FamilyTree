@model GMO.Family.Web.Models.LinkExistingViewModel
@{
    ViewData["Title"] = Model.ActionLabel;
}
<h1>@Model.ActionLabel</h1>
<p class="lead">Link an existing person in this tree as @Model.ActionLabel.ToLower() of <strong>@Model.ContextMemberName</strong>.</p>

@if (Model.Candidates.Count == 0)
{
    <p class="text-muted">No one else in this tree can be linked (everyone is already linked, or the limit of two parents is reached).</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to tree</a>
}
else
{
    <form asp-action="LinkExisting" method="post" class="row g-2">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="ContextMemberId" />
        <input type="hidden" asp-for="FamilyTreeId" />
        <input type="hidden" asp-for="RelationshipType" />
        <input type="hidden" asp-for="IsChild" />
        <input type="hidden" asp-for="ContextMemberName" />
        <input type="hidden" asp-for="ActionLabel" />
        <div class="col-12">
            <label class="form-label">Select person to link</label>
            <select asp-for="ExistingMemberId" class="form-select">
                <option value="">-- Choose --</option>
                @foreach (var c in Model.Candidates)
                {
                    <option value="@c.Id">@c.DisplayName</option>
                }
            </select>
            <span asp-validation-for="ExistingMemberId" class="text-danger"></span>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Link</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-link">Cancel</a>
        </div>
    </form>
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
