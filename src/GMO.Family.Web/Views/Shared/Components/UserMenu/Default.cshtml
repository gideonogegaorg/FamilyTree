@model GMO.Family.Web.ViewComponents.UserMenuViewModel

@if (string.IsNullOrEmpty(Model.Email))
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Sign in</a>
        </li>
    </ul>
}
else
{
<div class="d-flex align-items-center gap-3">
    <div class="d-none d-md-flex flex-column align-items-end text-end" style="line-height: 1.25;">
        <span class="text-white text-decoration-none small">@Model.Email</span>
        <span class="text-white-50 small">@(Model.CurrentFamilyTree?.Name ?? "No family tree")</span>
    </div>
    <div class="dropdown position-relative">
        <button class="btn btn-link p-0 border-0 rounded-circle" type="button" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            @if (!string.IsNullOrEmpty(Model.PhotoUrl))
            {
                <img src="@Model.PhotoUrl" alt="Profile" class="rounded-circle" width="36" height="36" style="object-fit: cover;" />
            }
            else
            {
                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary text-white" style="width: 36px; height: 36px; font-size: 1rem;" aria-hidden="true">@(Model.Email.Length > 0 ? char.ToUpperInvariant(Model.Email[0]) : '?')</span>
            }
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow mt-2" aria-labelledby="userMenuDropdown" style="min-width: 280px;">
            <li class="px-3 py-2 border-bottom">
                <div class="d-flex align-items-center gap-2">
                    <a asp-controller="Account" asp-action="UploadPhoto" class="dropdown-photo-link position-relative rounded-circle flex-shrink-0 text-decoration-none" title="Add or change your picture">
                        @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                        {
                            <img src="@Model.PhotoUrl" alt="" class="rounded-circle" width="48" height="48" style="object-fit: cover; display: block;" />
                        }
                        else
                        {
                            <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary text-white" style="width: 48px; height: 48px;">@(Model.Email.Length > 0 ? char.ToUpperInvariant(Model.Email[0]) : '?')</span>
                        }
                        <span class="user-menu-change-picture-hint position-absolute top-0 start-0 end-0 bottom-0 d-flex align-items-center justify-content-center rounded-circle bg-dark bg-opacity-75 text-white small text-center px-1" style="opacity: 0; transition: opacity 0.2s; pointer-events: none;">Add or change your picture</span>
                    </a>
                    <div class="small">
                        <strong>@Model.Email</strong>
                    </div>
                </div>
            </li>
            <li><hr class="dropdown-divider" /></li>
            <li class="dropdown-header small text-muted">Switch Family Tree</li>
            @foreach (var tree in Model.FamilyTrees)
            {
                <li>
                    <form asp-controller="Account" asp-action="SwitchFamilyTree" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@tree.Id" />
                        <button type="submit" class="dropdown-item @(Model.CurrentFamilyTree?.Id == tree.Id ? "active" : "")">
                            @tree.Name
                        </button>
                    </form>
                </li>
            }
            @if (Model.FamilyTrees.Count == 0)
            {
                <li><span class="dropdown-item text-muted small">No family trees yet</span></li>
            }
            <li><hr class="dropdown-divider" /></li>
            <li>
                <a class="dropdown-item" asp-controller="FamilyTree" asp-action="Create">Create new Family Tree</a>
            </li>
            <li><hr class="dropdown-divider" /></li>
            <li class="dropdown-header small text-muted">Tree layout</li>
            <li class="px-3 py-2">
                <div class="btn-group btn-group-sm w-100" role="group">
                    <form asp-controller="Account" asp-action="SetTreeViewOrientation" method="post" class="d-inline flex-grow-1">
                        <input type="hidden" name="orientation" value="0" />
                        <button type="submit" class="btn @(Model.TreeViewOrientation == GMO.Family.Web.Data.TreeViewOrientation.Vertical ? "btn-primary" : "btn-outline-secondary") w-100">Vertical</button>
                    </form>
                    <form asp-controller="Account" asp-action="SetTreeViewOrientation" method="post" class="d-inline flex-grow-1">
                        <input type="hidden" name="orientation" value="1" />
                        <button type="submit" class="btn @(Model.TreeViewOrientation == GMO.Family.Web.Data.TreeViewOrientation.Horizontal ? "btn-primary" : "btn-outline-secondary") w-100">Horizontal</button>
                    </form>
                </div>
            </li>
            <li><hr class="dropdown-divider" /></li>
            <li>
                <form asp-controller="Account" asp-action="SignOut" method="post">
                    <button type="submit" class="dropdown-item text-danger">Sign out</button>
                </form>
            </li>
        </ul>
    </div>
</div>
}
