@{
    ViewData["Title"] = "Upload profile picture";
}

<h1 class="ft-page-title">Profile picture</h1>
@if (TempData["PhotoError"] != null)
{
    <p class="text-danger">@TempData["PhotoError"]</p>
}
@if (TempData["PhotoSuccess"] != null)
{
    <p class="text-success">@TempData["PhotoSuccess"]</p>
}
<form asp-action="UploadPhoto" method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label for="photo" class="form-label">Choose image (JPG, PNG, GIF, WebP)</label>
        <input type="file" name="photo" id="photo" class="form-control" accept=".jpg,.jpeg,.png,.gif,.webp" />
    </div>
    <div class="ft-form-actions">
        <button type="submit" class="btn btn-primary">Upload</button>
        <a asp-controller="Home" asp-action="Index" class="ft-link">Cancel</a>
    </div>
</form>
