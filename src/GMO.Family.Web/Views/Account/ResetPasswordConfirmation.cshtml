@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Reset password confirmation";
}

<div class="card login-card mx-auto bg-white p-4">
    <div class="card-body p-0">
        <h1 class="h4 mb-4 fw-bold text-dark">Family Tree</h1>
        <p class="mb-3">Your password has been reset. You can now log in with your new password.</p>
        <p class="mb-0 text-center small">
            <a asp-action="Login" class="text-primary text-decoration-none">Log in</a>
        </p>
    </div>
</div>
