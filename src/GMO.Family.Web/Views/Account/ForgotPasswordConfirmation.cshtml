@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Forgot password confirmation";
}

<div class="card login-card mx-auto bg-white p-4">
    <div class="card-body p-0">
        <h1 class="h4 mb-4 fw-bold text-dark">Family Tree</h1>
        <p class="mb-3">If an account exists for that email, we've sent a link to reset your password. Check your inbox (and spam folder).</p>
        <p class="mb-0 text-center small">
            <a asp-action="Login" class="text-primary text-decoration-none">Back to log in</a>
        </p>
    </div>
</div>
