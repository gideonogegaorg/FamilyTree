<div class="modal fade" id="memberPhotoModal" tabindex="-1" aria-labelledby="memberPhotoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="memberPhotoModalLabel">Picture</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="member-photo-form" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <input type="hidden" id="member-photo-member-id" name="memberId" value="" />
                    <div class="profile-photo-preview-wrap mb-3 text-center">
                        <img id="member-photo-preview" src="" alt="" class="rounded-circle profile-photo-preview-img d-none" />
                        <span id="member-photo-preview-placeholder" class="profile-photo-preview-placeholder rounded-circle user-menu-avatar d-inline-flex align-items-center justify-content-center">?</span>
                    </div>
                    <div class="mb-3">
                        <label for="member-photo-file" class="form-label">Choose image (JPG, PNG, GIF, WebP)</label>
                        <input type="file" name="photo" id="member-photo-file" class="form-control" accept=".jpg,.jpeg,.png,.gif,.webp" />
                    </div>
                    <p id="member-photo-error" class="text-danger small mb-0 d-none" role="alert"></p>
                </div>
                <div class="modal-footer justify-content-between">
                    <button type="button" class="btn btn-link text-danger p-0 d-none" id="member-photo-remove">Remove photo</button>
                    <div class="d-flex gap-2 ms-auto">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="member-photo-submit">Upload</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
