@model GMO.Family.Web.Data.FamilyTree
@{
    ViewData["Title"] = "Delete Family Tree";
}
<h1>Delete</h1>
<p class="text-danger">Are you sure you want to delete this family tree?</p>
<p class="text-danger fw-semibold">All data in this tree will be permanently lost: every member and every relationship will be deleted and cannot be undone.</p>
<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>
    <dt class="col-sm-2">Uid</dt>
    <dd class="col-sm-10"><code>@Model.Uid</code></dd>
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-link">Cancel</a>
</form>
